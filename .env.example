# Database
POSTGRES_USER=ecostream
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=ecostream_db
DATABASE_URL=postgresql://ecostream:change_me_strong_password@localhost:5432/ecostream_db

# Auth
SECRET_KEY=generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Groq API (LOCKED: llama3-8b-8192, temp 0.2 — per CLAUDE.md R7)
# Free key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIR=data/chroma_db

# YOLO
YOLO_MODEL_PATH=ml-models/yolo/weights/best.pt
YOLO_CONF_THRESHOLD=0.25
YOLO_IOU_THRESHOLD=0.45

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
UPLOAD_DIR=data/uploads
MAX_UPLOAD_SIZE_MB=10

# CORS (comma-separated; override in production)
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:5173
